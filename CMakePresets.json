{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER": "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl",
                "PSI_PRESET_NAME": "${presetName}",
                "ENABLE_LOGGER": "ON"
            },
            "environment": {
                "LLVM_LIB": "C:/Program Files/LLVM/lib/clang/22/lib/windows"
            }
        },
        {
            "name": "windows-debug",
            "displayName": "Debug (clang-cl, no sanitizers)",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN_UBSAN": "OFF"
            }
        },
        {
            "name": "windows-debug-asan",
            "displayName": "Debug (clang-cl, ASAN+UBSan)",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN_UBSAN": "ON"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Release (clang-cl)",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_ASAN_UBSAN": "OFF"
            }
        },
        {
            "name": "windows-release-asan",
            "displayName": "Release (clang-cl, ASAN+UBSan)",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_ASAN_UBSAN": "ON"
            }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "PSI_PRESET_NAME": "${presetName}",
                "ENABLE_LOGGER": "OFF"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Debug (GCC, no sanitizers)",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN_UBSAN": "OFF"
            }
        },
        {
            "name": "linux-debug-asan",
            "displayName": "Debug (GCC, ASAN+UBSan)",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN_UBSAN": "ON"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Release (GCC)",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_ASAN_UBSAN": "OFF"
            }
        },
        {
            "name": "linux-release-asan",
            "displayName": "Release (GCC, ASAN+UBSan)",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_ASAN_UBSAN": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug"
        },
        {
            "name": "windows-debug-asan",
            "configurePreset": "windows-debug-asan"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release"
        },
        {
            "name": "windows-release-asan",
            "configurePreset": "windows-release-asan"
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        },
        {
            "name": "linux-debug-asan",
            "configurePreset": "linux-debug-asan"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        },
        {
            "name": "linux-release-asan",
            "configurePreset": "linux-release-asan"
        }
    ],
    "testPresets": [
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "windows-debug-asan",
            "configurePreset": "windows-debug-asan",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "windows-release-asan",
            "configurePreset": "windows-release-asan",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "linux-debug-asan",
            "configurePreset": "linux-debug-asan",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        },
        {
            "name": "linux-release-asan",
            "configurePreset": "linux-release-asan",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": false
            }
        }
    ]
}
